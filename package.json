{
  "name": "sap-cap-fe",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "start-dev": "cds-serve --profile dev",
    "start-prod": "cds-serve --profile production",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "watch-products-cap-cds": "cds watch --open productscapcds/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy sap-cap-fe --delete-services --delete-service-keys --delete-service-brokers",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-products-xml-annotations": "cds watch --open productsxmlannotations/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-products-flexible-programming-model": "cds watch --open productsflexibleprogrammingmodel/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[dev]": {
        "db": {
          "kind": "sqlite",
          "model": [
            "db/schema"
          ]
        },
        "auth": {
          "kind": "dummy"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/products-cap-cds",
    "app/products-xml-annotations",
    "app/products-flexible-programming-model"
  ]
}
