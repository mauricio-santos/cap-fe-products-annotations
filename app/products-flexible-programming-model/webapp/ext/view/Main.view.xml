<mvc:View controllerName="productsflexibleprogrammingmodel.ext.view.Main"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:macros="sap.fe.macros"
>

    <f:DynamicPage id="idMainDynamicPage" >

        <f:title>
            <f:DynamicPageTitle id="idMainDynamicPageTitle">
                <f:heading>
                    <Text id="idProductsFlexibleProgrammingModelText" text="{i18n>appDescription}"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader id="idMainDynamicPageHeader">
                <f:content>
                    <macros:FilterBar id="idMainFilterBar" metaPath="@com.sap.vocabularies.UI.v1.SelectionFields"/>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <macros:Table id="idMainTable" metaPath="@com.sap.vocabularies.UI.v1.LineItem" filterBar="idMainFilterBar"/>
        </f:content>

        <f:footer>
        </f:footer>

    </f:DynamicPage>

</mvc:View>